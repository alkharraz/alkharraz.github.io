---
layout: base.njk
title: blog
---

<h1>blog</h1>

{% if collections.post.length %}
<ul class="post-list">
  {%- for post in collections.post -%}
  <li>
    <span class="post-date">{{ post.date | dateFilter }}</span>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  </li>
  {%- endfor -%}
</ul>
{% else %}
<p style="color: var(--muted);">No posts yet.</p>
{% endif %}
